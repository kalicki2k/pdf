{
  "name": "kalle/pdf",
  "description": "A lightweight, native PDF engine for PHP for creating structured PDF documents programmatically",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "pdf",
    "document",
    "generator",
    "rendering"
  ],
  "homepage": "https://github.com/kalicki2k/pdf",
  "support": {
    "issues": "https://github.com/kalicki2k/pdf/issues",
    "source": "https://github.com/kalicki2k/pdf"
  },
  "autoload": {
    "psr-4": {
      "Kalle\\Pdf\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Kalle\\Pdf\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "phpstan": "vendor/bin/phpstan analyse -c phpstan.neon",
    "test": "phpunit -c phpunit.xml",
    "test:coverage": "XDEBUG_MODE=coverage phpunit -c phpunit.xml --coverage-text",
    "test:coverage-html": "XDEBUG_MODE=coverage phpunit -c phpunit.xml --coverage-html var/coverage",
    "cs": "php-cs-fixer fix --config=.php-cs-fixer.php --verbose",
    "cs:check": "php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff --verbose"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5",
    "friendsofphp/php-cs-fixer": "^3.80"
  },
  "require": {
    "php": "^8.5"
  }
}
