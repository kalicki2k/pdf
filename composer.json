{
  "name": "kalle/pdf",
  "description": "A lightweight, native PDF engine for PHP for creating structured PDF documents programmatically",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "pdf",
    "document",
    "generator",
    "rendering"
  ],
  "homepage": "https://github.com/kalicki2k/pdf",
  "support": {
    "issues": "https://github.com/kalicki2k/pdf/issues",
    "source": "https://github.com/kalicki2k/pdf"
  },
  "autoload": {
    "psr-4": {
      "Kalle\\Pdf\\": "src/"
    },
    "classmap": [
      "src/Document/Document.php",
      "src/Page/Page.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Kalle\\Pdf\\Tests\\": "tests/"
    },
    "files": [
      "tests/Document/Support/DocumentRandomBytesStub.php"
    ]
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5",
    "friendsofphp/php-cs-fixer": "^3.80"
  },
  "scripts": {
    "cs": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --sequential",
    "cs:check": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --sequential",
    "docs:build": "php bin/generate-docs.php",
    "example:pdfa1a": "php examples/pdf-a-1a.php",
    "example:pdfa1b": "php examples/pdf-a-1b.php",
    "example:pdfa2a": "php examples/pdf-a-2a.php",
    "example:pdfa2b": "php examples/pdf-a-2b.php",
    "example:pdfa2u": "php examples/pdf-a-2u.php",
    "example:pdfa3a": "php examples/pdf-a-3a.php",
    "example:pdfa3b": "php examples/pdf-a-3b.php",
    "example:pdfa3u": "php examples/pdf-a-3u.php",
    "example:pdfa4": "php examples/pdf-a-4.php",
    "example:pdfa4e": "php examples/pdf-a-4e.php",
    "example:pdfa4f": "php examples/pdf-a-4f.php",
    "example:pdfua1": "php examples/pdf-ua-1.php",
    "phpstan": "phpstan analyse --debug",
    "test": "phpunit --configuration phpunit.xml.dist",
    "test:coverage": "XDEBUG_MODE=coverage phpunit --configuration phpunit.xml.dist --coverage-text",
    "test:coverage-html": "XDEBUG_MODE=coverage phpunit --configuration phpunit.xml.dist --coverage-html var/coverage",
    "test:pdfa-regression": "bash bin/test-pdfa-regression.sh",
    "test:pdfua-regression": "bash bin/test-pdfua-regression.sh",
    "test:pdfua-negative-regression": "bash bin/test-pdfua-negative-regression.sh",
    "validate:pdfa": "bash bin/validate-pdfa.sh"
    ,
    "validate:pdfua": "bash bin/validate-pdfua.sh"
  },
  "require": {
    "php": "^8.4",
    "ext-mbstring": "*"
  },
  "extra": {
    "branch-alias": {
      "dev-main": "0.1.x-dev"
    }
  }
}
